# ==================================
# Python cache
# ==================================
__pycache__/
*.pyc
*.pyo
*.pyd

# ==================================
# Databases
# ==================================
*.sqlite
*.db

# ==================================
# Virtual environments
# ==================================
venv/
env/
.venv/

# ==================================
# Environment files
# ==================================
.env
.env.*

# ==================================
# IDE / Editor files
# ==================================
.idea/
.vscode/

# ==================================
# OS files
# ==================================
.DS_Store
Thumbs.db

# ==================================
# Runtime output (Streaming sinks)
# ==================================
output/
alerts/
*.jsonl
*.json
*.tmp
*.log

# ==================================
# Kafka / Redis local state (optional)
# ==================================
kafka_data/

# ==================================
# Python packaging
# ==================================
build/
dist/
*.egg-info/

# ==================================
# Generated streaming data
# ==================================
data/input/*.csv
output/staging/*
output/reports/*.json

# ==================================
# Keep folder placeholders
# ==================================
!data/input/.gitkeep
!output/
!output/staging/
!output/staging/.gitkeep
!output/reports/
!output/reports/.gitkeep